<h1>task index</h1>

<ul>
<% @sections.each do |section| %>
  <li>
    <%= section.title %>
    <ul>
      <% section.tasks.each do |task| %>
        <li><%= link_to task.title, conversion_voluntary_task_edit_path(@project.id, section.slug, task.slug) %></li>
       <% end %>
    </ul>
  </li>
<% end %>
</ul>
