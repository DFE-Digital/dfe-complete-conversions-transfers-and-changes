<h1 class="govuk-heading-l">Academy conversion</h1>

<p><a href="<%= new_project_path %>" role="button" draggable="false" class="govuk-button govuk-button--start" data-module="govuk-button">
  Start now
  <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
    <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z" />
  </svg></a></p>

<table class="govuk-table">
  <caption class="govuk-table__caption govuk-table__caption--m">Existing projects</caption>
  <thead class="govuk-table__head">
    <tr class="govuk-table__row">
      <th scope="col" class="govuk-table__header">Project</th>
      <th scope="col" class="govuk-table__header">Created at</th>
    </tr>
  </thead>
  <tbody class="govuk-table__body">
    <% @projects.each do |project| %>
      <tr class="govuk-table__row">
        <th scope="row" class="govuk-table__header"><%= link_to "Project ##{project.id}", project_path(project)  %></th>
        <td class="govuk-table__cell"><%= project.created_at %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p><%= link_to "See prototype task list",
  tasks_path,
  class: 'govuk-button govuk-button--secondary',
  data: {module: "govuk-button"}
%></p>
